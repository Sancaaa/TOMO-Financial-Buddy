# Salin ke .env lalu sesuaikan. JANGAN commit .env ke git.

# --- Database ---
POSTGRES_USER=finance
POSTGRES_PASSWORD=ganti-password-ini
POSTGRES_DB=finance

# --- Auth / JWT ---
# Buat secret acak: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=ganti-dengan-secret-acak-panjang
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# --- User awal (dibuat sekali saat pertama kali start) ---
INITIAL_USERNAME=admin
INITIAL_PASSWORD=ganti-password-login-ini

# --- Telegram bot ---
# Token dari @BotFather
TELEGRAM_BOT_TOKEN=
# chat_id kamu (kirim pesan ke bot, lihat balasannya untuk tahu chat_id). Bot hanya
# merespons chat_id ini.
TELEGRAM_CHAT_ID=
# Secret acak untuk verifikasi webhook: python -c "import secrets; print(secrets.token_urlsafe(24))"
TELEGRAM_WEBHOOK_SECRET=
# Zona waktu untuk batas hari & backdate (WITA = 8)
TZ_OFFSET_HOURS=8

# --- Scheduler (otomasi) ---
# Menjalankan: recurring tx, digest harian, cek alert budget, review akhir bulan.
SCHEDULER_ENABLED=true
# Jam lokal kirim digest harian + cek alert (0-23)
DIGEST_HOUR=21

# --- OCR (LLM Vision) ---
# API key dari aistudio.google.com/apikey — dipakai untuk membaca foto struk
GEMINI_API_KEY=
# Model OCR. Default hemat (free-tier); pakai gemini-2.5-pro untuk akurasi maksimal.
OCR_MODEL=gemini-2.5-flash
# Folder penyimpanan foto struk di dalam container (volume Docker)
RECEIPTS_DIR=/data/receipts
OCR_MAX_IMAGE_MB=10


# --- Web app statis ---
# Folder hasil build web PWA yang disajikan FastAPI. Di Docker sudah di-set /app/web.
# Untuk dev lokal biarkan kosong (jalankan Vite terpisah).
STATIC_DIR=

# --- CORS ---
# Web disajikan satu origin dgn API, jadi CORS umumnya tak perlu di produksi.
# Untuk dev (Vite di :5173) proxy sudah menangani; "*" aman.
CORS_ORIGINS=*

# --- Akses publik ---
# TIDAK pakai Caddy. API di-bind ke 127.0.0.1:8737 (lihat docker-compose), lalu
# Cloudflare Tunnel (cloudflared) mengarah ke http://localhost:8737 dan menyediakan
# HTTPS + domain. Webhook Telegram = https://<domain-kamu>/telegram/webhook
